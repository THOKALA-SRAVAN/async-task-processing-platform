# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/async_tasks"

# Redis
REDIS_URL="redis://localhost:6379"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# BullMQ
QUEUE_NAME=tasks
WORKER_CONCURRENCY=5
JOB_ATTEMPTS=3
JOB_BACKOFF=2000
