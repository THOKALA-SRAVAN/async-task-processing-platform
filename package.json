{
  "name": "async-task-platform",
  "version": "1.0.0",
  "description": "Production-grade async task processing platform",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:api": "nodemon --exec tsx src/server.ts",
    "dev:worker": "nodemon --exec tsx src/worker/worker.ts",
    "build": "tsc --project tsconfig.json",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/worker/worker.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/__tests__/unit",
    "test:integration": "vitest run src/__tests__/integration"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bullmq": "^5.7.0",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.3.0",
    "ioredis": "^5.3.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "nodemon": "^3.1.0",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.5"
  }
}
